
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamStatus {
  LOOKING
  NEED_MEMBERS
  FULL
}

enum Result {
  WINNER
  FINALIST
  PARTICIPANT
}

enum Role {
  DEVELOPER
  DESIGNER
  PRODUCT_MANAGER
  RESEARCHER
}

enum SkillCategory {
  FRONTEND
  BACKEND
  FULLSTACK
  DATA_SCIENCE
  MACHINE_LEARNING
  DEVOPS
  MOBILE
  UI_UX_DESIGN
  OTHER
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  passwordHash String
  username        String   @unique
  university      String?
  yearOfStudy     Int?
  role        Role?
  bio         String?
  githubURL   String?
  linkedinURL String?
  preferredContact String?
  avatarURL   String?
  createdHackathons Hackathon[]
  pastHackathons PastHackathon[]
  Hackathons HackathonParticipant[]
  refreshTokens RefreshToken[]
  skills      UserSkill[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Skill {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  category    SkillCategory
  users       UserSkill[]
}

model UserSkill {
  id      Int     @id @default(autoincrement())
  user    User    @relation(fields: [userId], references: [id])
  userId  Int
  skill   Skill   @relation(fields: [skillId], references: [id])
  skillId Int
}

model Hackathon {
  id                   Int      @id @default(autoincrement())
  name                 String
  description          String
  startDate            DateTime
  registrationDeadline DateTime
  maxTeamSize          Int
  externalUrl          String
  createdBy            Int
  createdByUser        User     @relation(fields: [createdBy], references: [id])
  participants         HackathonParticipant[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model HackathonParticipant {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id])
  hackathonId Int
  teamStatus TeamStatus
  spotsAvailable Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([userId, hackathonId])
}

model PastHackathon {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  name        String
  year        Int
  role        Role
  result      Result
  location    String
  createdAt   DateTime  @default(now())
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  tokenHash   String    @unique
  expiresAt   DateTime
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  @@index([userId]) // Index for faster lookups by userId
}